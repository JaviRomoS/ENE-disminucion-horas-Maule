subset1 <- update(subset1, uno = 1)
tabla3 <- svyby(
~uno,
~ano_encuesta + tipo_contrato,
design = subset1,
FUN = svytotal,
na.rm = TRUE,
vartype = c("ci")
) %>%
rename(
total = uno,
total_low = ci_l,
total_upp = ci_u
) %>%
group_by(ano_encuesta) %>%
mutate(
year_total = sum(total),
propor = total / year_total,
propor_low = total_low / year_total,
propor_upp = total_upp / year_total
) %>%
ungroup()
View(tabla3)
summary(model1b)
