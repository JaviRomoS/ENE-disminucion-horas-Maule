"Manufactura"))
plotm3_h <- ggplot(pred3_hombres, aes(x = x + 2022, y = predicted, color = group)) +
geom_line(linewidth = 1.1) +
geom_point(size = 2.5) +
geom_ribbon(aes(ymin = conf.low, ymax = conf.high, fill = group),
