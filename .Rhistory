tabla4 <- svyby(
~uno,
~ano_encuesta + mujer,
design = subset(subset1, tipo_contrato == "1"),
FUN = svytotal,
na.rm = TRUE,
vartype = c("ci")
) %>%
rename(
total = uno,
total_low = ci_l,
total_upp = ci_u
) %>%
group_by(ano_encuesta) %>%
mutate(
year_total = sum(total),
propor = total / year_total,
propor_low = total_low / year_total,
propor_upp = total_upp / year_total
) %>%
ungroup()
View(tabla4)
