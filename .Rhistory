model1b <- lm(habituales ~ mujer +
year_c + region +
antiguedad +
con_pareja +
tipo_contrato +
tamano +
rama, data = ene_pond)
model1c <- lm(hab_tramos ~ mujer +
year_c + region +
antiguedad +
con_pareja +
tipo_contrato +
tamano +
rama, data = ene)
summary(model1a)
summary(model1b)
vif_tabla <- as.data.frame(vif(model1b))
if (ncol(vif_tabla) == 3) {
vif_tabla$GVIF_ajustado <- vif_tabla$GVIF^(1 / (2 * vif_tabla$Df))
vif_tabla <- vif_tabla %>%
mutate(variable = rownames(vif_tabla)) %>%
select(variable, GVIF, Df, GVIF_ajustado)
} else {
vif_tabla <- vif_tabla %>%
mutate(variable = rownames(vif_tabla)) %>%
rename(VIF = .)}
